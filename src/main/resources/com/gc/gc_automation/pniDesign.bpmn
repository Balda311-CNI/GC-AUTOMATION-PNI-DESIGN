      <bpmn2:script><![CDATA[System.out.println("============================================");
System.out.println("=== pniDesign - Create result: COMPLETED ===");
System.out.println("============================================");

java.util.Map<String, Object> edgeEquipmentMap = new java.util.HashMap<>();
edgeEquipmentMap.put("edgeEquipmentCrossId", kcontext.getVariable("edgeEquipmentCrossId"));
edgeEquipmentMap.put("edgeEquipmentName", kcontext.getVariable("___TODO___"));
edgeEquipmentMap.put("cageCrossId", kcontext.getVariable("cageCrossId"));
edgeEquipmentMap.put("cageName", kcontext.getVariable("___TODO___"));

java.util.Map<String, Object> map = new java.util.HashMap<>();
map.put("id", kcontext.getVariable("_order"));
map.put("version", kcontext.getVariable("version"));
map.put("status", "COMPLETED");
map.put("serviceCrossId", kcontext.getVariable("serviceCrossId"));
map.put("opticalPathCrossId", kcontext.getVariable("opticalPathCrossId"));
map.put("opticalPathPrmId", kcontext.getVariable("opticalPathPrmId"));
map.put("placeCrossId", kcontext.getVariable("placeCrossId"));
map.put("placeSmwId", kcontext.getVariable("placeSmwId"));
map.put("projectCrossId", kcontext.getVariable("projectCrossId"));
map.put("edgeEquipment", edgeEquipmentMap);
kcontext.setVariable("response", map);]]></bpmn2:script>
