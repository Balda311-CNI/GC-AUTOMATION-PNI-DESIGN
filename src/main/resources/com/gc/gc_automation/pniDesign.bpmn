    <bpmn2:task id="_4C9BFDFB-52A1-4C33-B044-7D6CEF45D913" drools:taskName="SdcApiCall" name="REST_API_CALL:
cross/findAddress">
      <bpmn2:documentation id="_RcxlNDmGEfGeGeWP6G0fcQ"><![CDATA[Calls automatons source "cross/executeQuery/findAddress". Expected: source returns addressId, addressCrossId, latitude, longitude per row.]]></bpmn2:documentation>
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[REST_API_CALL:
cross/findAddress]]></drools:metaValue>
        </drools:metaData>
        <drools:onEntry-script scriptFormat="http://www.java.com/java">
          <drools:script><![CDATA[System.out.println("=================================================================");
System.out.println("=== pniDesign - REST_API_CALL: cross/executeQuery/findAddress ===");
System.out.println("=================================================================");]]></drools:script>
        </drools:onEntry-script>
        <drools:onExit-script scriptFormat="http://www.java.com/java">
          <drools:script><![CDATA[System.out.println("Data Outputs: addressList=" + addressList);
if (addressList != null) {
    java.util.List<?> list = (java.util.List<?>) addressList;
    if (list.size() == 1) {
        java.util.Map<String, Object> firstRow = (java.util.Map<String, Object>) list.get(0);
        if (firstRow.get("addressId") != null) {
            kcontext.setVariable("addressId", ((Number) firstRow.get("addressId")).longValue());
        }
        if (firstRow.get("addressCrossId") != null) {
            kcontext.setVariable("addressCrossId", (String) firstRow.get("addressCrossId"));
        }
        if (firstRow.get("latitude") != null) {
            kcontext.setVariable("addressLatitude", ((Number) firstRow.get("latitude")).doubleValue());
        }
        if (firstRow.get("longitude") != null) {
            kcontext.setVariable("addressLongitude", ((Number) firstRow.get("longitude")).doubleValue());
        }
    }
}]]></drools:script>
        </drools:onExit-script>
