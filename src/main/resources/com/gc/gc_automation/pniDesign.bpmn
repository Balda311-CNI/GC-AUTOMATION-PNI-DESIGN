    <bpmn2:task id="_4C9BFDFB-52A1-4C33-B044-7D6CEF45D913" drools:taskName="SdcApiCall" name="REST_API_CALL:
cross/findAddress">
      <bpmn2:documentation id="_VW07Hjo3EfGeGeWP6G0fcQ"><![CDATA[Calls automatons source "cross/executeQuery/findAddress". Expected: source returns addressId, addressCrossId, latitude, longitude per row.]]></bpmn2:documentation>
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[REST_API_CALL:
cross/findAddress]]></drools:metaValue>
        </drools:metaData>
        <drools:onEntry-script scriptFormat="http://www.java.com/java">
          <drools:script><![CDATA[System.out.println("=================================================================");
System.out.println("=== pniDesign - REST_API_CALL: cross/executeQuery/findAddress ===");
System.out.println("=================================================================");]]></drools:script>
        </drools:onEntry-script>
        <drools:onExit-script scriptFormat="http://www.java.com/java">
          <drools:script><![CDATA[// Debug output
System.out.println("Data Outputs: addressList=" + addressList);

if (addressList != null) {
    java.util.List<?> list = (java.util.List<?>) addressList;

    if (list.size() == 1) {
        java.util.Map<String, Object> firstRow = (java.util.Map<String, Object>) list.get(0);

        addressId = ((Number) firstRow.get("addressId")).longValue();
        System.out.println("addressId=" + addressId);
        kcontext.setVariable("addressId", addressId);

        addressCrossId = ((String) firstRow.get("addressCrossId"));
        System.out.println("addressCrossId=" + addressCrossId);
        kcontext.setVariable("addressCrossId", addressCrossId);

        addressLatitude = ((Number) firstRow.get("latitude")).doubleValue();
        System.out.println("addressLatitude=" + addressLatitude);
        kcontext.setVariable("addressLatitude", addressLatitude);

        addressLongitude = ((Number) firstRow.get("longitude")).doubleValue();
        System.out.println("addressLongitude=" + addressLongitude);
        kcontext.setVariable("addressLongitude", addressLongitude);
    }
}]]></drools:script>
        </drools:onExit-script>
      </bpmn2:extensionElements>
