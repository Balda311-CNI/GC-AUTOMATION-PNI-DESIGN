      <bpmn2:script><![CDATA[System.out.println("=========================================");
System.out.println("=== pniDesign - Create result: FAILED ===");
System.out.println("=========================================");

// Try errorMessage variable first (set manually by some paths)
String errorMessage = (String) kcontext.getVariable("errorMessage");

// If not set, try to extract from caught exception (sub-process intermediate error)
if (errorMessage == null) {
    Exception error = (Exception) kcontext.getVariable("caughtException");
    if (error != null) {
        errorMessage = error.getMessage();
        kcontext.setVariable("caughtException", null);
    }
}

if (errorMessage == null) {
    throw new IllegalArgumentException("errorMessage cannot be null. Set it by: kcontext.setVariable(\"errorMessage\", \"MESSAGE\");");
}

java.util.Map<String, Object> map = new java.util.HashMap<>();
map.put("id", kcontext.getVariable("_order"));
map.put("version", kcontext.getVariable("version"));
map.put("status", "FAILED");
map.put("error", errorMessage);
kcontext.setVariable("response", map);]]></bpmn2:script>
