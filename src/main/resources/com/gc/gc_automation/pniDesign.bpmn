map.put("OpticalPathPrmId", kcontext.getVariable("opticalPathPrmId"));
map.put("localityCrossId", kcontext.getVariable("localityCrossId"));
map.put("localitySmwId", kcontext.getVariable("localitySmwId"));
map.put("projectCrossId", kcontext.getVariable("projectCrossId"));
map.put("edgeEquipment", kcontext.getVariable("edgeEquipment"));
kcontext.setVariable("response", map);]]></bpmn2:script>
