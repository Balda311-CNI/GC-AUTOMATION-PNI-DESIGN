      <bpmn2:conditionExpression xsi:type="bpmn2:tFormalExpression" id="_gwyvETlmEfGeGeWP6G0fcQ" language="http://www.java.com/java"><![CDATA[boolean result = localityCrossId == null || ((String) localityCrossId).isEmpty();
