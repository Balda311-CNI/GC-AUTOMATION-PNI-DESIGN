      <bpmn2:conditionExpression xsi:type="bpmn2:tFormalExpression" id="_SXWxQ0DuEfGrK4FBZUBLpg" language="http://www.java.com/java"><![CDATA[boolean result = false;
if (serviceComponents != null) {
    java.util.List<?> list = (java.util.List<?>) serviceComponents;
    for (Object item : list) {
        java.util.Map<String, Object> row = (java.util.Map<String, Object>) item;
        String componentTypeName = (String) row.get("componentTypeName");
        if ("SC_ACCESS".equals(componentTypeName)) {
            kcontext.setVariable("serviceComponentAccessCrossId", (String) row.get("crossId"));
            result = true;
        }
    }
}
System.out.println("VALIDATION: Service with SC_ACCESS service component: " + result);
return result;]]></bpmn2:conditionExpression>
