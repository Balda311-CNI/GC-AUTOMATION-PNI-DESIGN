      <bpmn2:conditionExpression xsi:type="bpmn2:tFormalExpression" id="_id0fUjlrEfGeGeWP6G0fcQ" language="http://www.java.com/java"><![CDATA[boolean result = addressList != null && ((java.util.List<?>) addressList).size() > 1;
