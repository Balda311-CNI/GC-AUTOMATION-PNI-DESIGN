    <bpmn2:task id="_EFEED2F2-D72F-4F9F-890D-70F6C5CF29BE" drools:taskName="SdcApiCall" name="REST_API_CALL:
cross/addOpticalPathToAServiceComponent">
      <bpmn2:documentation id="_nmB-JUGhEfGrK4FBZUBLpg"><![CDATA[Add provisioning Optical Path to a Service Component of the created Service.]]></bpmn2:documentation>
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[REST_API_CALL:
cross/addOpticalPathToAServiceComponent]]></drools:metaValue>
        </drools:metaData>
        <drools:onEntry-script scriptFormat="http://www.java.com/java">
          <drools:script><![CDATA[System.out.println("==================================================================================");
System.out.println("=== pniDesign_Service_Access - REST_API_CALL: cross/addOpticalPathToAServiceComponent ===");
System.out.println("==================================================================================");

java.util.List<Object> list = new java.util.ArrayList<>();

java.util.Map<String, Object> resource = new java.util.HashMap<>();
resource.put("crossId", kcontext.getVariable("opticalPathCrossId"));
resource.put("primary", true);
list.add(resource);

kcontext.setVariable("serviceComponentPhysicalConnectivityResources", list);]]></drools:script>
        </drools:onEntry-script>
      </bpmn2:extensionElements>
