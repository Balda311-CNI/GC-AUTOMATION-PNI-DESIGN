    <bpmn2:sequenceFlow id="_FD9A4BE1-3EBE-4BBA-80CD-F529CA339665" name="PLACEMENT" sourceRef="_9A8B4FB1-0B86-4AF4-B0E7-74815845B805" targetRef="_F21826C9-87CC-4D97-AD31-8FBA33C1EF5F">
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[PLACEMENT]]></drools:metaValue>
        </drools:metaData>
      </bpmn2:extensionElements>
      <bpmn2:conditionExpression xsi:type="bpmn2:tFormalExpression" id="_nmB-IUGhEfGrK4FBZUBLpg" language="http://www.java.com/java"><![CDATA[boolean result = false;
if (physicalAccessServiceComponents != null) {
    java.util.List<?> list = (java.util.List<?>) physicalAccessServiceComponents;
    for (Object item : list) {
        java.util.Map<String, Object> row = (java.util.Map<String, Object>) item;
        String componentTypeName = (String) row.get("componentTypeName");
        if ("PLACEMENT".equals(componentTypeName)) {
            kcontext.setVariable("serviceComponentPlacementCrossId", (String) row.get("crossId"));
            result = true;
        }
    }
}
System.out.println("VALIDATION: Service with PLACEMENT service component: " + result);
return result;]]></bpmn2:conditionExpression>
    </bpmn2:sequenceFlow>
