    <bpmn2:task id="_F21826C9-87CC-4D97-AD31-8FBA33C1EF5F" drools:taskName="SdcApiCall" name="REST_API_CALL:
cross/addPlaceToAServiceComponent">
      <bpmn2:documentation id="_nmB-OUGhEfGrK4FBZUBLpg"><![CDATA[Add consumers Place to a Service Component of the created Service.]]></bpmn2:documentation>
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[REST_API_CALL:
cross/addPlaceToAServiceComponent]]></drools:metaValue>
        </drools:metaData>
        <drools:onEntry-script scriptFormat="http://www.java.com/java">
          <drools:script><![CDATA[System.out.println("==================================================================================");
System.out.println("=== pniDesign_Service_Access - REST_API_CALL: cross/addPlaceToAServiceComponent ===");
System.out.println("==================================================================================");

java.util.List<Object> list = new java.util.ArrayList<>();

java.util.Map<String, Object> resource = new java.util.HashMap<>();
resource.put("crossId", kcontext.getVariable("placeCrossId"));
resource.put("primary", true);
list.add(resource);

kcontext.setVariable("serviceComponentPlacementResources", list);]]></drools:script>
        </drools:onEntry-script>
      </bpmn2:extensionElements>
