      <bpmn2:conditionExpression xsi:type="bpmn2:tFormalExpression" id="_NkaLIUGoEfGrK4FBZUBLpg" language="http://www.java.com/java"><![CDATA[boolean result = resultList == null || ((java.util.List<?>) resultList).isEmpty();
System.out.println("VALIDATION: Address not found: " + result );
if (result) {
    kcontext.setVariable("errorMessage", "Address not found");
}
return result;]]></bpmn2:conditionExpression>
