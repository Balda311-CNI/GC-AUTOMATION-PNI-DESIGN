      <bpmn2:incoming>_37A50F5D-8662-44FA-8179-9C337D988F8E</bpmn2:incoming>
      <bpmn2:outgoing>_D82CE95A-06CE-438E-BE01-C669C10CEDB7</bpmn2:outgoing>
      <bpmn2:script><![CDATA[System.out.println("====================================================");
System.out.println("resourceAvailabilityCheck - Create result: COMPLETED");
System.out.println("====================================================");

java.util.Map<String, Object> dataAddressCoordinates = new java.util.HashMap<>();
dataAddressCoordinates.put("latitude", kcontext.getVariable("addressLatitude"));
dataAddressCoordinates.put("longitude", kcontext.getVariable("addressLongitude"));

java.util.Map<String, Object> dataAddress = new java.util.HashMap<>();
dataAddress.put("globalReferenceId", kcontext.getVariable("globalReferenceId"));
dataAddress.put("coordinates", dataAddressCoordinates);

java.util.Map<String, Object> map = new java.util.HashMap<>();
map.put("version", kcontext.getVariable("version"));
map.put("status", "COMPLETED");
map.put("address", dataAddress);
map.put("results", kcontext.getVariable("equipmentList"));
kcontext.setVariable("response", map);]]></bpmn2:script>
    </bpmn2:scriptTask>
