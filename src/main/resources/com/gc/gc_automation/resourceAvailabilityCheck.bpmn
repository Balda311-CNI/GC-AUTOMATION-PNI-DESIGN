      <bpmn2:incoming>_4552BF1E-0446-48CA-9F56-C154E86526CD</bpmn2:incoming>
      <bpmn2:outgoing>_791104D8-347E-48B5-AD87-161D5D4814FC</bpmn2:outgoing>
      <bpmn2:script><![CDATA[System.out.println("=================================================");
System.out.println("resourceAvailabilityCheck - Create result: FAILED");
System.out.println("=================================================");

String errorMessage = (String) kcontext.getVariable("errorMessage");
if ( errorMessage == null ) {
    throw new IllegalArgumentException("errorMessage cannot be null. Set it by: kcontext.setVariable(\"errorMessage\", \"MESSAGE\");");
}

java.util.Map<String, Object> map = new java.util.HashMap<>();
map.put("id", kcontext.getVariable("_order"));
map.put("version", kcontext.getVariable("version"));
map.put("status", "FAILED");
map.put("error", errorMessage);
kcontext.setVariable("response", map);]]></bpmn2:script>
    </bpmn2:scriptTask>
    <bpmn2:task id="_762FDAA2-F5AE-4703-A797-3E4F32217D69" drools:taskName="SdcApiCall" name="REST_API_CALL:
cross/findEquipments">
      <bpmn2:documentation id="_NkaLT0GoEfGrK4FBZUBLpg"><![CDATA[Calls automatons source with name "cross/executeQuery/findEquipments" using domain REST_API_CALL.]]></bpmn2:documentation>
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[REST_API_CALL:
cross/findEquipments]]></drools:metaValue>
        </drools:metaData>
        <drools:onEntry-script scriptFormat="http://www.java.com/java">
          <drools:script><![CDATA[System.out.println("===========================================================================================");
System.out.println("resourceAvailabilityCheck - REST_API_CALL: REST_API_CALL: cross/executeQuery/findEquipments");
System.out.println("===========================================================================================");

resultList = null;

// Initialize `equipmentTypesConverted` as it was not initiallized yet, thus `null`
java.util.List<String> _equipmentTypesConverted = new java.util.ArrayList<>();
for (String equipmentType : (java.util.List<String>) equipmentTypes) {
    if ("MAS".equals(equipmentType)) {
        _equipmentTypesConverted.add("NETWORK_TG_ACCESS_MAS_nodes");
    } else if ("MER".equals(equipmentType)) {
        _equipmentTypesConverted.add("NETWORK_TG_EDGE_MER_nodes");
    } else {
        throw new IllegalArgumentException("Unknown equipmentType: " + equipmentType);
    }
}
kcontext.setVariable("equipmentTypesConverted", _equipmentTypesConverted);

System.out.println("equipmentTypes converted from " + equipmentTypes + " to " + _equipmentTypesConverted);
]]></drools:script>
        </drools:onEntry-script>
        <drools:onExit-script scriptFormat="http://www.java.com/java">
          <drools:script><![CDATA[// Debug output
System.out.println("Data Outputs: resultList=" + resultList);

if (resultList != null) {
    java.util.List<?> list = (java.util.List<?>) resultList;

    for (Object element : list) {
        java.util.Map<String, Object> row = (java.util.Map<String, Object>) element;
        
        // Prepare nested coordinates
        java.util.Map<String, Object> coordinates = new java.util.HashMap<>();

        Object latObj = row.get("latitude");
        if (latObj != null) {
            coordinates.put("latitude", latObj);
        }

        Object lonObj = row.get("longitude");
        if (lonObj != null) {
            coordinates.put("longitude", lonObj);
        }

        // Remove original fields (safe even if not present)
        row.remove("latitude");
        row.remove("longitude");

        // Add only if at least one coordinate exists
        if (!coordinates.isEmpty()) {
            row.put("coordinates", coordinates);
        }
    }
}]]></drools:script>
        </drools:onExit-script>
      </bpmn2:extensionElements>
