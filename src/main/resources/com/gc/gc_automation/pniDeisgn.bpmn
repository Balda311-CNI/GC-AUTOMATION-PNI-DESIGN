get data">
      <bpmn2:documentation id="_AwyG0D-8EfGrK4FBZUBLpg"><![CDATA[Retrieves data from automaton's tmf_store table using TMF_STORE domain and JSONATA transformation.]]></bpmn2:documentation>
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[TMF_STORE:
get data]]></drools:metaValue>
        </drools:metaData>
        <drools:onEntry-script scriptFormat="http://www.java.com/java">
          <drools:script><![CDATA[System.out.println("===========================================");
System.out.println("=== pniDesign - Get data from TMF_STORE ===");
System.out.println("===========================================");]]></drools:script>
        </drools:onEntry-script>
        <drools:onExit-script scriptFormat="http://www.java.com/java">
          <drools:script><![CDATA[System.out.println(
    String.format("version=%s addressMasterId=%s edgeEquipmentCrossId=%s serviceId=%s crossProjectName=%s productId=%s",
    version, addressMasterId, edgeEquipmentCrossId, serviceId, crossProjectName, productId)
);]]></drools:script>
        </drools:onExit-script>
      </bpmn2:extensionElements>
